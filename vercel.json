{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 13 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<sub>.*)\\.vercel\\.app"
        }
      ],
      "destination": "https://michigantroutreport.com/:path*",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "trout.chrisizworski.com"
        }
      ],
      "destination": "https://michigantroutreport.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/river/:id",
      "destination": "/api/river/[id]"
    },
    {
      "source": "/rivers/:id",
      "destination": "/api/river/[id]"
    },
    {
      "source": "/api/weekend",
      "destination": "/api/weekend"
    },
    {
      "source": "/api/recommend",
      "destination": "/api/recommend"
    },
    {
      "source": "/api/create-checkout",
      "destination": "/api/create-checkout"
    },
    {
      "source": "/api/webhook-stripe",
      "destination": "/api/webhook-stripe"
    },
    {
      "source": "/api/alerts-manage",
      "destination": "/api/alerts-manage"
    },
    {
      "source": "/api/directory",
      "destination": "/api/directory"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<sub>.*)\\.vercel\\.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/webhook-stripe",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "x-vercel-skip-body-parser",
          "value": "1"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "$schema": "https://openapi.vercel.sh/vercel.json"
}
