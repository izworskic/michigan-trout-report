{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/river/:id",
      "destination": "/api/river/[id]"
    },
    {
      "source": "/rivers/:id",
      "destination": "/api/river/[id]"
    },
    {
      "source": "/api/weekend",
      "destination": "/api/weekend"
    },
    {
      "source": "/api/recommend",
      "destination": "/api/recommend"
    },
    {
      "source": "/api/create-checkout",
      "destination": "/api/create-checkout"
    },
    {
      "source": "/api/webhook-stripe",
      "destination": "/api/webhook-stripe"
    },
    {
      "source": "/api/alerts-manage",
      "destination": "/api/alerts-manage"
    },
    {
      "source": "/api/directory",
      "destination": "/api/directory"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/webhook-stripe",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "x-vercel-skip-body-parser",
          "value": "1"
        }
      ]
    }
  ]
}